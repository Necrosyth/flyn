{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:manual": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:direct": "ts-node src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1057.0",
    "@aws-sdk/client-dynamodb": "^3.1028.0",
    "@aws-sdk/client-lambda": "^3.1001.0",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/client-sqs": "^3.1057.0",
    "@aws-sdk/lib-dynamodb": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@google/generative-ai": "^0.24.1",
    "@hapi/boom": "^10.0.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/websockets": "^11.1.15",
    "@types/pg": "^8.16.0",
    "@vapi-ai/server-sdk": "^0.11.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.2.4",
    "firebase-admin": "^13.6.0",
    "libphonenumber-js": "^1.13.3",
    "mailparser": "^3.9.4",

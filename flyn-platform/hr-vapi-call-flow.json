{
    "_comment": "Flow — HR to Vapi Call. Extracts users from HR module and initiates a Vapi web call passing assistantOverrides.",
    "nodes": [
        {
            "id": "trigger_1",
            "type": "trigger",
            "name": "Manual Trigger",
            "position": {
                "x": 60,
                "y": 240
            },
            "config": {
                "trigger_type": "manual",
                "event_name": "start_hr_calling_campaign",
                "description": "Trigger to extract HR users and start outbound Vapi calls"
            }
        },
        {
            "id": "hr_1",
            "type": "hr",
            "name": "HR — Get Employee 1",
            "position": {
                "x": 380,
                "y": 100
            },
            "config": {
                "operation": "get_employee",
                "entityId": "emp_001"
            }
        },
        {
            "id": "vapi_1",
            "type": "vapi",
            "name": "Vapi — Call Employee 1",
            "position": {
                "x": 700,
                "y": 100
            },
            "config": {
                "operation": "create_call",
                "assistantId": "asst_hr_agent_123",
                "phoneNumberId": "phone_company_main",
                "customer": {
                    "number": "{{hr_1.employee.phone}}"
                },
                "assistantOverrides": {
                    "variableValues": {
                        "leadName": "{{hr_1.employee.name}}",
                        "company": "Flow Hub",
                        "repName": "General Purpose HR Agent",
                        "offer": "update on remote work policies",
                        "source": "HR Database",
                        "notes": "{{hr_1.employee.notes}}"
                    }
                }
            }
        },
        {
            "id": "hr_2",
            "type": "hr",
